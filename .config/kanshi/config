profile laptop-only {
    output eDP-1 {
        enable
        scale 1
        position 0,0
    }
}

profile docked {
    output HDMI-A-1 {
        enable
        mode 1600x900@60Hz
        scale 1
        position 0,0
    }

    output eDP-1 {
        enable
        scale 1
        position 1600,0
    }
}

profile external-only {
    output eDP-1 disable
    output HDMI-A-1 {
        mode 1600x900@60Hz
        position 0,0
        scale 1
    }
}
